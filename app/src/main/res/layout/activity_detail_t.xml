                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/grey_1000">

                <androidx.appcompat.widget.LinearLayoutCompat
